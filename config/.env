# config/.env.example
# Exemplo de configuração para o ambiente de testes OCPP
# Copie este arquivo para .env e ajuste os valores conforme necessário

#=======================================================================================
#									GENERAl
#=======================================================================================

# URL base do websocket do servidor SteVe (sem station_id)
WS_URL=ws://localhost:8081/

# Fator pelo qual o tempo é multiplicado durante a simulação  de transferência de energia.
TIME_SCALE=10

# Valor padrão de recarga (em kWh) a ser fornecido em uma transação 
RECHARGE_VALUE=5.0

#=======================================================================================
#							CHARGE POINT ATTRIBUTES
#=======================================================================================

#		*****	REQUIRED	****	

STATION_ID=cp001							# Identificador do posto (Charge Point)
CHARGE_POINT_MODEL=Optimus					# Modelo do posto (Charge Point)
CHARGE_POINT_VENDOR=The_Mobility_House		# Fabricante do posto (Charge Point)

#		*****	OPTIONAL	****	

CHARGE_POINT_SERIAL_NUMBER=CP-001
FIRMWARE_VERSION=0.0.1

#=======================================================================================
#								   VEHICLE
#=======================================================================================

#		*****	REQUIRED	****	

ID_TAG=A1B2C3D4								# Identificador do veículo 

#=======================================================================================
#							 STANDARD MEASUREMENTS
#=======================================================================================

#		*****	REQUIRED	****	

VOLTAGE=370.0								# Tensão de alimentação CA RMS (V)
CURRENT=15.0								# Corrente fluindo para o VE (UM)
MAX_CURRENT=100.0							# Corrente máxima oferecida ao veículo elétrico (UM)    

#		*****	OPTIONAL	****

FREQUENCY=60.0							# Frequência da rede (Hz)
TEMPERATURE=305.0							# Leitura da temperatura dentro do ponto de carregamento (K)

#=======================================================================================
#							   CONFIGURATION KEYS
#=======================================================================================

#		*****	REQUIRED	****	

#		----- Conexão e Batimento Cardíaco
HEARTBEAT_INTERVAL=60						# Intervalo entre heartbeats (em segundos)
CONNECTION_TIMEOUT=30						# Timeout para estabelecer conexão websocket (segundos)
RESET_RETRIES=50							# Número máximo de tentativas de reconexão
#		----- Metering Configuration
CLOCK_ALIGNED_DATA_INTERVAL=900				# Valor do intervalo de dados alinhado ao relógio (segundos)
METER_VALUES_ALIGNED_DATA=""				# Medidas a serem incluídas a cada ClockAlignedDataInterval
METER_VALUES_SAMPLE_INTERVAL=300			# Valor do intervalo de amostragens de medição (segundos)
METER_VALUES_SAMPLE_DATA=""					# Medindas a serem incluídos a cada MeterValuesSampledData
#		----- Medição Durante Parada de Transação
STOP_TXN_ALIGNED_DATA=""					# Medidas pariódicas a serem incluídas no StopTransaction.req
STOP_TXN_SAMPLE_DATA=""						# Medidas amostradas a serem incluídas no StopTransaction.req


#=======================================================================================
#									OUTROS
#=======================================================================================

BASE_DELAY=5.0								# Atraso base para backoff (segundos)
RESPONSE_TIMEOUT=30							# Timeout para aguardar resposta a chamadas OCPP (segundos)
CONNECTORS_QTY=2							# Número de conectores da estação de recarga
CONNECTOR1_INIT_ENERGY_IMPORT=10000.0		# Valor Inicial de Energy.Active.Import.Register do Conn. #01 (Wh)
CONNECTOR2_INIT_ENERGY_IMPORT=10000.0		# Valor Inicial de Energy.Active.Import.Register do Conn. #02 (Wh)